# Stripe Price IDs — subscripcion mensual + anual por plan
STRIPE_PRICE_INICIA_MONTHLY="price_xxx"
STRIPE_PRICE_INICIA_ANNUAL="price_xxx"
STRIPE_PRICE_DESPACHO_MONTHLY="price_xxx"
STRIPE_PRICE_DESPACHO_ANNUAL="price_xxx"
STRIPE_PRICE_FIRMA_MONTHLY="price_xxx"
STRIPE_PRICE_FIRMA_ANNUAL="price_xxx"

# Stripe Price IDs — setup fees one-off (Inicia no usa setup)
STRIPE_PRICE_SETUP_DESPACHO="price_xxx"
STRIPE_PRICE_SETUP_FIRMA="price_xxx"

# Anthropic (IA Autopilot) — leave empty for stub mode
ANTHROPIC_API_KEY=""

# App
APP_URL="http://localhost:3000"

# Crons (Vercel Cron) — secret compartido para autorizar disparos
CRON_SECRET=""

# Demo publica (true habilita /login?demo=1 y el cron de reseteo diario)
DEMO_ENABLED="false"

# Notificacion de nuevos leads (digest de stale-leads se envia aqui)
LEADS_NOTIFY_EMAIL=""

# Superadmin whitelist — emails del equipo Heredia separados por comas.
# Solo estos pueden acceder a /admin/metrics, /admin/funnel,
# /admin/demo-requests y dar trials desde /api/admin/orgs/[id]/trial.
# Vacio = panel admin inaccesible (fail-closed).
ADMIN_EMAILS=""

# Google SSO (opcional, plan Firma). Cuando ambas están definidas, /login
# muestra "Continuar con Google". GOOGLE_WORKSPACE_HD opcional restringe
# el dominio del Workspace al iniciar sesión.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_WORKSPACE_HD=""
