# Copia este archivo a `.env` y rellena tu clave de la API de Anthropic.
# Consíguela en https://console.anthropic.com/

ANTHROPIC_API_KEY=sk-ant-...

# Modelo de Claude a usar. Por defecto claude-sonnet-4-6 (rápido y económico).
# Para respuestas aún más profundas usa claude-opus-4-7.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Puerto en el que escucha el servidor.
PORT=3000
